# Copy to .env and adjust.
DATABASE_URL=postgresql+psycopg://gather:gather@localhost:5432/gather
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Storage adapter: "local" (Phase 0) or "s3" (later)
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./_storage

# S3 / R2 (used when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=

# AI provider: "stub" (Phase 0-2) or "claude" (Phase 3)
AI_PROVIDER=stub
ANTHROPIC_API_KEY=

# Notifier (transactional email/SMS): "console" prints invites/OTPs to the log
NOTIFIER_BACKEND=console
INVITATION_TTL_HOURS=168
OTP_TTL_MINUTES=10
REFRESH_TOKEN_EXPIRE_DAYS=30
